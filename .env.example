# Copy to .env and fill in. Never commit .env.

# --- Core ---
APP_ENV=local
APP_SECRET_KEY=change-me-dev-secret-key-min-32-chars-long
# Fernet key for encrypting stored OAuth tokens.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# --- Database ---
# Local docker-compose Postgres:
DATABASE_URL=postgresql+psycopg://nq:nq@localhost:5432/nq
# Neon (later): postgresql+psycopg://USER:PASSWORD@HOST/DB?sslmode=require

# --- Magic link auth ---
MAGIC_LINK_TTL_MINUTES=15
SESSION_TTL_HOURS=168
# Base URL the frontend/app is served from (used to build magic links)
APP_BASE_URL=http://localhost:8000

# --- LLM (optional for local dev; falls back to a template if unset) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- Report defaults ---
DEFAULT_GST_RATE=0.18

# --- Shopify OAuth (authorization-code flow for merchant stores) ---
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_SCOPES=read_orders
# Public HTTPS callback (a tunnel URL in local dev). Must be registered as an
# allowed redirect URL on the Shopify app. If empty, defaults to
# {APP_BASE_URL}/api/integrations/shopify/callback
SHOPIFY_REDIRECT_URI=
